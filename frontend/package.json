    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vite-plugin-istanbul": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.6",
    "workbox-window": "^7.4.0"
